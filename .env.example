AGW_LISTEN_ADDR=:11945
AGW_PUBLIC_BASE_URL=http://localhost:11945
AGW_DATABASE_DRIVER=sqlite
AGW_SQLITE_PATH=./data/gateway.db
AGW_SPOOL_DIR=./data/spool
AGW_COOKIE_SECURE=false
AGW_TENANT_HMAC_SECRET=replace-with-at-least-32-random-bytes
AGW_BOOTSTRAP_TENANT_ID=local
AGW_BOOTSTRAP_TENANT_NAME=Local
AGW_BOOTSTRAP_HOSTS=localhost,127.0.0.1
AGW_BOOTSTRAP_ADMIN_TOKEN=replace-with-a-random-bootstrap-token
# Browser authentication mode: oidc (default) or local.
AGW_AUTH_MODE=oidc
# Local mode uses a bcrypt hash; never commit a real password or hash.
# AGW_LOCAL_USERNAME=admin
# Quote bcrypt hashes so shells and Compose do not interpolate '$' characters.
# AGW_LOCAL_PASSWORD_HASH='$2a$12$replace-with-a-bcrypt-hash'
# AGW_LOCAL_DISPLAY_NAME=Administrator
# AGW_LOCAL_ROLES=user
AGW_PLATFORM_JWT_PUBLIC_KEY_FILE=./configs/platform-jwt-public.pem
AGW_PLATFORM_JWT_PRIVATE_KEY_FILE=./configs/platform-jwt-private.pem
AGW_PLATFORM_JWT_ISSUER=agent-gateway
AGW_SESSION_TTL=12h
AGW_ANONYMOUS_TTL=720h
AGW_OIDC_FLOW_TTL=10m
AGW_PLATFORM_TOKEN_TTL=720h
AGW_RESOURCE_TICKET_TTL=5m
AGW_SPOOL_TTL=30m
AGW_MAX_UPLOAD_BYTES=104857600
AGW_MAX_WS_MESSAGE_BYTES=1048576
AGW_WRITE_QUEUE_SIZE=256
AGW_PLATFORM_REQUEST_TIMEOUT=30s
AGW_RATE_LIMIT_PER_MINUTE=240
AGW_MAX_CONCURRENT_STREAMS=8
# AGW_ALLOWED_BROWSER_ORIGINS=https://app.example.com
